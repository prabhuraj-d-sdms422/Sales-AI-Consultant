# ════════════════════════════════════════════════════
# STARK DIGITAL AI SALES CONSULTANT — V1
# Copy this to .env and fill in your values
# ════════════════════════════════════════════════════

# ── APP ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM PROVIDER ─────────────────────────────────────
# Switch between: anthropic | openai | gemini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
LLM_TEMPERATURE=0.3
# Output token budget per reply. Too low causes cut-off mid-word; 4096 is safe for long sales answers.
LLM_MAX_TOKENS=4096
LLM_STREAMING=true

# ── TOKEN USAGE COSTING ────────────────────────────────
# Token counts come from provider usage metadata (real). Only USD->INR conversion depends on this rate.
USD_TO_INR_RATE=94.65

# ── VECTOR DB ─────────────────────────────────────────
# Abstraction built — NOT called in V1
VECTOR_DB_PROVIDER=pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=stark-ai-consultant

# ── REDIS ─────────────────────────────────────────────
REDIS_HOST=localhost
# Host port: use 6381 with `docker compose up -d redis` (see docker-compose.yml: "6381:6379").
# Use 6379 if Redis runs locally on the default port. Must match a listening port or you get "Connection refused".
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=86400

# ── GUARDRAILS ────────────────────────────────────────
INTENT_CONFIDENCE_THRESHOLD=0.70
STREAM_TOKEN_BUFFER=20
# Comma-separated competitor names (lowercase) for output CompetitorCheck — matches settings default if omitted
COMPETITOR_NAMES_BLOCKLIST=tcs,infosys,wipro,accenture,cognizant

# ── SESSION ───────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
SAVE_CONVERSATIONS_ENABLED=false

# ── STARK DIGITAL IDENTITY ────────────────────────────
CONSULTANT_NAME=Alex
COMPANY_NAME=Stark Digital
SALES_PHONE_NUMBER=+91-XXXXXXXXXX

# ── SENDGRID — lead email (after row is saved to data/leads.xlsx) ──
# Create an API key at https://app.sendgrid.com/settings/api_keys
# Verify sender identity (Single Sender or Domain Authentication) for SENDGRID_FROM_EMAIL.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@your-verified-domain.com
SENDGRID_FROM_NAME=Stark Digital AI Sales Consultant
# Comma-separated recipient(s), e.g. sales@company.com
SENDGRID_TO_EMAIL=sales@company.com
# true = SendGrid sandbox (no real delivery; use only for testing the API)
SENDGRID_SANDBOX_MODE=false

# ── GOOGLE SHEETS — lead tracker (optional) ────────────────────────
# Phase-2 style: append leads to a Google Sheet whenever a lead is captured.
# Requires: enable Google Sheets API + service account JSON key file.
# Share your target spreadsheet with the service account's client_email as Editor.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_sheets_credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Leads

# ── HUBSPOT CRM (optional) ─────────────────────────────────────────
# Create a Private App: Settings → Integrations → Private Apps → Create private app.
# Scopes: crm.objects.contacts (read/write), crm.objects.notes (read/write).
# Copy the access token below. Portal ID: from the URL when logged in (…/contacts/<PORTAL>/…).
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# ════════════════════════════════════════════════════
# PHASE 2 — uncomment when integrating
# ════════════════════════════════════════════════════
# ── PostgreSQL ────────────────────────────────────────
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=stark_ai_consultant
# POSTGRES_USER=stark_user
# POSTGRES_PASSWORD=your_password
# DATABASE_URL=postgresql+asyncpg://
#   stark_user:password@localhost:5432/stark_ai_consultant
